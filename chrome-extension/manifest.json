{
  "manifest_version": 3,
  "name": "Master Collection Companion",
  "version": "2.0.0",
  "description": "Paste Guard and interaction tools for Master Collection installs in Webflow Designer",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.design.webflow.com/*",
    "https://webflow.com/design/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.design.webflow.com/*",
        "https://webflow.com/design/*"
      ],
      "js": [
        "content/dom-discovery.js",
        "content/deletion-engine.js",
        "content/paste-guard.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
