{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "default": {
      "primary": {
        "$value": "#171717",
        "$type": "color"
      },
      "secondary": {
        "$value": "#525252",
        "$type": "color"
      },
      "tertiary": {
        "$value": "#16A34A",
        "$type": "color"
      },
      "tertiary-dark": {
        "$value": "#15803D",
        "$type": "color"
      },
      "neutral": {
        "$value": "#FAFAFA",
        "$type": "color"
      },
      "surface": {
        "$value": "#F5F5F5",
        "$type": "color"
      },
      "border": {
        "$value": "#D4D4D4",
        "$type": "color"
      },
      "on-primary": {
        "$value": "#FAFAFA",
        "$type": "color"
      },
      "primary-dark": {
        "$value": "#FAFAFA",
        "$type": "color"
      },
      "secondary-dark": {
        "$value": "#A3A3A3",
        "$type": "color"
      },
      "tertiary-dark-mode": {
        "$value": "#22C55E",
        "$type": "color"
      },
      "neutral-dark": {
        "$value": "#0A0A0A",
        "$type": "color"
      },
      "surface-dark": {
        "$value": "#171717",
        "$type": "color"
      },
      "border-dark": {
        "$value": "#404040",
        "$type": "color"
      }
    }
  },
  "typography": {
    "headline-lg": {
      "fontFamily": {
        "$value": "DM Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "40px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 500,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.2,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.01em",
        "$type": "dimension"
      }
    },
    "headline-md": {
      "fontFamily": {
        "$value": "DM Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "24px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 500,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.3,
        "$type": "number"
      }
    },
    "body-md": {
      "fontFamily": {
        "$value": "DM Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "15px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.7,
        "$type": "number"
      }
    },
    "label-md": {
      "fontFamily": {
        "$value": "DM Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "12px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 500,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "0.04em",
        "$type": "dimension"
      }
    }
  },
  "borderRadius": {
    "sm": {
      "$value": "4px",
      "$type": "dimension"
    },
    "md": {
      "$value": "8px",
      "$type": "dimension"
    }
  },
  "spacing": {
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "12px",
      "$type": "dimension"
    },
    "md": {
      "$value": "20px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "32px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "48px",
      "$type": "dimension"
    },
    "2xl": {
      "$value": "64px",
      "$type": "dimension"
    },
    "3xl": {
      "$value": "80px",
      "$type": "dimension"
    },
    "4xl": {
      "$value": "120px",
      "$type": "dimension"
    },
    "5xl": {
      "$value": "160px",
      "$type": "dimension"
    },
    "section": {
      "$value": "80px",
      "$type": "dimension"
    },
    "pad-button": {
      "$value": "16px",
      "$type": "dimension"
    }
  },
  "extras": {
    "version": "alpha",
    "name": "Sanctuary Tech",
    "description": "Trauma-informed, low-stress aesthetic for crisis support, healthcare, legal aid, and privacy tools. Monospace type, dashed borders, muted tones, generous whitespace.",
    "components": {
      "button-primary": {
        "backgroundColor": "{colors.tertiary}",
        "textColor": "{colors.on-primary}",
        "typography": "{typography.label-md}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.pad-button}"
      },
      "button-primary-hover": {
        "backgroundColor": "{colors.tertiary-dark}"
      },
      "card-default": {
        "backgroundColor": "{colors.surface}",
        "textColor": "{colors.primary}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.lg}"
      },
      "dashed-panel": {
        "backgroundColor": "{colors.neutral}",
        "textColor": "{colors.primary}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.lg}"
      }
    }
  }
}
