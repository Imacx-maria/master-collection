      },
      "fontSize": {
        "$value": "clamp(18px, 1.7vw, 24px)",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.15,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.02em",
        "$type": "dimension"
      }
    },
    "body-sm": {
      "fontFamily": {
        "$value": "Inter Tight, Helvetica Neue, Arial, sans-serif",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "13px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.45,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.01em",
        "$type": "dimension"
      }
    },
    "label": {
