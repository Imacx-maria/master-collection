      },
      "lineHeight": {
        "$value": 0.88,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.055em",
        "$type": "dimension"
      },
      "textTransform": {
        "$value": "uppercase",
        "$type": "string"
      }
    },
    "display-lg": {
      "fontFamily": {
        "$value": "Inter Tight, Satoshi, Neue Montreal, Helvetica Neue, Arial, sans-serif",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "clamp(56px, 9vw, 120px)",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 300,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.9,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.045em",
        "$type": "dimension"
      },
      "textTransform": {
