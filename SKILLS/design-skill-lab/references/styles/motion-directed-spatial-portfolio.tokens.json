        "$type": "color"
      },
      "graphite": {
        "$value": "#1a1a1a",
        "$type": "color"
      },
      "text-primary": {
        "$value": "#f4f4f0",
        "$type": "color"
      },
      "text-secondary": {
        "$value": "#c9c7c1",
        "$type": "color"
      },
      "text-muted": {
        "$value": "#8a8882",
        "$type": "color"
