        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.98,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.035em",
