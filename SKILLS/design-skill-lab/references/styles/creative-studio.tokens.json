    "4xl": {
      "$value": "80px",
      "$type": "dimension"
    },
    "5xl": {
      "$value": "128px",
      "$type": "dimension"
    },
    "section": {
      "$value": "80px",
      "$type": "dimension"
    },
    "pad-button": {
      "$value": "14px",
      "$type": "dimension"
    },
    "pad-band": {
      "$value": "48px",
      "$type": "dimension"
    }
