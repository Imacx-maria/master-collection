      "fontWeight": {
        "$value": 700,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.98,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.035em",
        "$type": "dimension"
      }
    },
    "headline-xl": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "96px",
        "$type": "dimension"
