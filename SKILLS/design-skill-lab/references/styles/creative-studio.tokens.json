      "secondary": {
        "$value": "#434645",
        "$type": "color"
      },
      "tertiary": {
        "$value": "#FF531F",
        "$type": "color"
      },
      "tertiary-light-1": {
        "$value": "#FFF0EB",
        "$type": "color"
      },
      "tertiary-light-2": {
