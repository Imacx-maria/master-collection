{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "default": {
      "primary": {
        "$value": "#181818",
        "$type": "color"
      },
      "secondary": {
        "$value": "#888888",
        "$type": "color"
      },
      "tertiary": {
        "$value": "#DDDDDD",
        "$type": "color"
      },
      "neutral": {
        "$value": "#EAEAEA",
        "$type": "color"
      },
      "surface": {
        "$value": "#FFFFFF",
        "$type": "color"
      },
      "surface-dark": {
        "$value": "#2A2A2A",
        "$type": "color"
      },
      "on-primary": {
        "$value": "#DDDDDD",
        "$type": "color"
      }
    }
  },
  "typography": {
    "display-xl": {
      "fontFamily": {
        "$value": "Anton",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "160px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.92,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.02em",
        "$type": "dimension"
      }
    },
    "display-lg": {
      "fontFamily": {
        "$value": "Anton",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "120px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.95,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.02em",
        "$type": "dimension"
      }
    },
    "headline-lg": {
      "fontFamily": {
        "$value": "Anton",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "64px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.98,
        "$type": "number"
      }
    },
    "body-md": {
      "fontFamily": {
        "$value": "Roboto Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "14px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.5,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "0.08em",
        "$type": "dimension"
      }
    },
    "label-md": {
      "fontFamily": {
        "$value": "Roboto Mono",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "12px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 700,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "0.2em",
        "$type": "dimension"
      }
    }
  },
  "borderRadius": {
    "sm": {
      "$value": "0px",
      "$type": "dimension"
    },
    "md": {
      "$value": "0px",
      "$type": "dimension"
    }
  },
  "spacing": {
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "32px",
      "$type": "dimension"
    },
    "2xl": {
      "$value": "48px",
      "$type": "dimension"
    },
    "3xl": {
      "$value": "64px",
      "$type": "dimension"
    },
    "4xl": {
      "$value": "96px",
      "$type": "dimension"
    },
    "5xl": {
      "$value": "160px",
      "$type": "dimension"
    },
    "grid": {
      "$value": "60px",
      "$type": "dimension"
    }
  },
  "extras": {
    "version": "alpha",
    "name": "Neo-Brutalist",
    "description": "Hard-edged, high-contrast, grid-driven system for bold landing pages, edgy brands, and poster-like tech showcases.",
    "components": {
      "button-primary": {
        "backgroundColor": "{colors.primary}",
        "textColor": "{colors.on-primary}",
        "typography": "{typography.label-md}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.md}"
      },
      "button-primary-hover": {
        "backgroundColor": "{colors.on-primary}",
        "textColor": "{colors.primary}"
      },
      "card-default": {
        "backgroundColor": "{colors.surface}",
        "textColor": "{colors.primary}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.lg}"
      },
      "meta-chip": {
        "backgroundColor": "{colors.primary}",
        "textColor": "{colors.secondary}",
        "typography": "{typography.label-md}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.sm}"
      }
    }
  }
}
