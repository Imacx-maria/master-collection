{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "default": {
      "primary": {
        "$value": "#1D1F1E",
        "$type": "color"
      },
      "secondary": {
        "$value": "#444745",
        "$type": "color"
      },
      "tertiary": {
        "$value": "#DBD5C9",
        "$type": "color"
      },
      "neutral": {
        "$value": "#F4F3F0",
        "$type": "color"
      },
      "surface": {
        "$value": "#F1EDE1",
        "$type": "color"
      },
      "surface-dark": {
        "$value": "#161616",
        "$type": "color"
      },
      "on-primary": {
        "$value": "#F4F3F0",
        "$type": "color"
      }
    }
  },
  "typography": {
    "display-xl": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "128px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.9,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.03em",
        "$type": "dimension"
      }
    },
    "display-lg": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "88px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.92,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.04em",
        "$type": "dimension"
      }
    },
    "headline-lg": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "56px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 0.95,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.06em",
        "$type": "dimension"
      }
    },
    "body-md": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "16px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 300,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1.5,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "-0.02em",
        "$type": "dimension"
      }
    },
    "label-caps": {
      "fontFamily": {
        "$value": "Inter",
        "$type": "fontFamily"
      },
      "fontSize": {
        "$value": "12px",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "lineHeight": {
        "$value": 1,
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "0.08em",
        "$type": "dimension"
      }
    }
  },
  "borderRadius": {
    "sm": {
      "$value": "0px",
      "$type": "dimension"
    },
    "md": {
      "$value": "0px",
      "$type": "dimension"
    }
  },
  "spacing": {
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "32px",
      "$type": "dimension"
    },
    "2xl": {
      "$value": "48px",
      "$type": "dimension"
    },
    "3xl": {
      "$value": "64px",
      "$type": "dimension"
    },
    "4xl": {
      "$value": "80px",
      "$type": "dimension"
    },
    "5xl": {
      "$value": "128px",
      "$type": "dimension"
    },
    "section": {
      "$value": "80px",
      "$type": "dimension"
    },
    "pad-button": {
      "$value": "12px",
      "$type": "dimension"
    }
  },
  "extras": {
    "version": "alpha",
    "name": "Editorial Portfolio",
    "description": "Warm, image-led, gallery-adjacent editorial system for portfolios, showcases, and cultural presentation surfaces.",
    "components": {
      "button-primary": {
        "backgroundColor": "{colors.primary}",
        "textColor": "{colors.on-primary}",
        "typography": "{typography.label-caps}",
        "rounded": "{rounded.sm}",
        "padding": "{spacing.pad-button}"
      },
      "button-primary-hover": {
        "backgroundColor": "{colors.secondary}"
      },
      "panel-overlay": {
        "backgroundColor": "{colors.neutral}",
        "textColor": "{colors.primary}",
        "padding": "{spacing.lg}"
      },
      "caption-strip": {
        "backgroundColor": "{colors.tertiary}",
        "textColor": "{colors.secondary}",
        "typography": "{typography.label-caps}",
        "padding": "{spacing.pad-button}"
      },
      "footer-band": {
        "backgroundColor": "{colors.surface-dark}",
        "textColor": "{colors.on-primary}",
        "padding": "{spacing.lg}"
      }
    }
  }
}
